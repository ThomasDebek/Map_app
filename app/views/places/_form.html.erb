<%= form_with(model: place, class: "contents") do |form| %>
  <% if place.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(place.errors.count, "error") %> prohibited this place from being saved:</h2>

      <ul class="list-disc ml-6">
        <% place.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: [
      "block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full bg-zinc-800 text-white placeholder-gray-400",
      { "border-gray-400 focus:outline-blue-600": place.errors[:name].none?,
        "border-red-400 focus:outline-red-600": place.errors[:name].any? }
    ] %>
  </div>

  <div class="my-5">
    <%= form.label :location %>
    <%= form.text_field :location, class: [
      "block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full bg-zinc-800 text-white placeholder-gray-400",
      { "border-gray-400 focus:outline-blue-600": place.errors[:location].none?,
        "border-red-400 focus:outline-red-600": place.errors[:location].any? }
    ] %>
  </div>

  <div class="my-5">
    <%= form.label :x %>
    <%= form.text_field :x, class: [
      "block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full bg-zinc-800 text-white placeholder-gray-400",
      { "border-gray-400 focus:outline-blue-600": place.errors[:x].none?,
        "border-red-400 focus:outline-red-600": place.errors[:x].any? }
    ] %>
  </div>

  <div class="my-5">
    <%= form.label :y %>
    <%= form.text_field :y, class: [
      "block shadow rounded-md border outline-none px-3 py-2 mt-2 w-full bg-zinc-800 text-white placeholder-gray-400",
      { "border-gray-400 focus:outline-blue-600": place.errors[:y].none?,
        "border-red-400 focus:outline-red-600": place.errors[:y].any? }
    ] %>
  </div>

  <div class="inline">
    <%= form.submit class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>